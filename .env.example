TTS_PROVIDER=qwen_local
QWEN_TTS_ENDPOINT=http://qwen-tts:7860/tts
QWEN_TTS_MODEL=Qwen/Qwen3-TTS-12Hz-1.7B-CustomVoice
QWEN_TTS_DEVICE=cuda:0
QWEN_TTS_ATTN_IMPLEMENTATION=sdpa
QWEN_TTS_INSTRUCT=用平穩一致的講課語氣
QWEN_TTS_SEED=316
QWEN_TTS_DO_SAMPLE=true
# Tight sampling keeps tone consistent and suppresses stray laughs/sighs/speed drift.
QWEN_TTS_TEMPERATURE=0.6
QWEN_TTS_TOP_P=0.8
QWEN_TTS_TOP_K=10
QWEN_TTS_SUBTALKER_DOSAMPLE=true
QWEN_TTS_SUBTALKER_TEMPERATURE=0.6
QWEN_TTS_SUBTALKER_TOP_P=0.8
QWEN_TTS_SUBTALKER_TOP_K=10
# Big chunks with aggressive merging keep whole sentences (and short neighbors)
# in one generation pass, so pace/tone stay continuous across commas.
# 1024 new tokens covers ~85s of audio at the 12Hz codec (a 200-char Chinese chunk can run ~60s).
QWEN_TTS_MAX_CHARS_PER_CHUNK=200
QWEN_TTS_MIN_CHUNK_CHARS=80
QWEN_TTS_MAX_NEW_TOKENS=1024
QWEN_TTS_SENTENCE_GAP_MS=700
QWEN_TTS_PARAGRAPH_GAP_MS=1000
QWEN_TTS_PAUSE_DEFAULT_MS=1000
# Parallel TTS worker processes; each loads its own model copy (~14GB VRAM).
# Keep TTS_WORKERS (backend concurrency) slightly above QWEN_TTS_WORKERS so
# uvicorn's random request routing keeps every worker busy.
QWEN_TTS_WORKERS=2
TTS_WORKERS=3
QWEN_TTS_MAX_BATCH_CHUNKS=32
QWEN_TTS_VOICE=Ryan
QWEN_TTS_VOICES=Ryan:Ryan,Aiden:Aiden,Vivian:Vivian,Serena:Serena,Uncle_Fu:Uncle Fu,Dylan:Dylan,Eric:Eric,Ono_Anna:Ono Anna,Sohee:Sohee
KOKORO_TTS_ENDPOINT=http://kokoro-tts:7861/tts
# cuda:N runs the 82M model on an idle GPU (~1.5s per page); cpu also works.
KOKORO_TTS_DEVICE=cpu
# Parallel service processes; backend render jobs fan out across all of them.
KOKORO_TTS_WORKERS=4
KOKORO_TTS_SPEED=1.0
KOKORO_TTS_VOICE=af_heart
KOKORO_TTS_VOICES=af_heart:Heart (US female),af_bella:Bella (US female),af_nicole:Nicole (US female),af_sky:Sky (US female),am_michael:Michael (US male),am_fenrir:Fenrir (US male),am_puck:Puck (US male),bf_emma:Emma (UK female),bm_george:George (UK male),bm_fable:Fable (UK male)
BARK_TTS_ENDPOINT=http://bark-tts:7862/tts
# suno/bark-small also works and cuts VRAM/latency roughly in half.
BARK_TTS_MODEL=suno/bark
BARK_TTS_DEVICE=cuda:0
# Sampling is what makes Bark takes vary; the Reroll button sends a fresh seed
# per request, while this seed keeps unrerolled generations reproducible.
BARK_TTS_SEED=316
BARK_TTS_DO_SAMPLE=true
BARK_TTS_SEMANTIC_TEMPERATURE=0.7
BARK_TTS_COARSE_TEMPERATURE=0.7
BARK_TTS_FINE_TEMPERATURE=0.5
# Bark degrades past ~13-14s of speech per generation, so keep chunks short.
BARK_TTS_MAX_CHARS_PER_CHUNK=220
BARK_TTS_MIN_CHUNK_CHARS=0
# Each worker loads its own model copy (~5GB VRAM fp16); keep at 1 unless the GPU has room.
BARK_TTS_WORKERS=1
BARK_TTS_VOICE=v2/en_speaker_6
BARK_TTS_VOICES=v2/en_speaker_6:English Speaker 6,v2/en_speaker_9:English Speaker 9,v2/en_speaker_3:English Speaker 3,v2/zh_speaker_1:Chinese Speaker 1,v2/zh_speaker_4:Chinese Speaker 4,v2/zh_speaker_9:Chinese Speaker 9,v2/ja_speaker_3:Japanese Speaker 3,v2/ko_speaker_0:Korean Speaker 0
OPENAI_API_KEY=
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_TTS_VOICE=alloy
OPENAI_TTS_VOICES=alloy:Alloy,ash:Ash,ballad:Ballad,coral:Coral,echo:Echo,fable:Fable,nova:Nova,onyx:Onyx,sage:Sage,shimmer:Shimmer,verse:Verse
BACKEND_CORS_ORIGINS=*
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
# libx264 beats h264_nvenc for still-image segments on many-core machines:
# parallel NVENC sessions serialize on GPU context creation, while x264
# scales cleanly across workers (measured 3.1s vs 9.7s for 16 segments).
VIDEO_ENCODER=libx264
VIDEO_SEGMENT_WORKERS=8
# Still-image slides need no motion; 6fps renders ~3x faster than 25fps.
VIDEO_FPS=6
